{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://developers.stellar.org/schemas/sdp/Profile.json",
  "title": "Profile",
  "type": "object",
  "properties": {
    "first_name": {
      "type": "string",
      "example": "Jane"
    },
    "last_name": {
      "type": "string",
      "example": "Doe"
    },
    "email": {
      "type": "string",
      "example": "jdoe@mail.org"
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "organization_name": {
      "type": "string"
    }
  },
  "example": {
    "first_name": "Jane",
    "last_name": "Doe",
    "email": "jdoe@mail.org",
    "roles": [
      "developer"
    ],
    "organization_name": "Stellar Aid"
  }
}