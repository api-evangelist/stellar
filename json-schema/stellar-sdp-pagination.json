{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://developers.stellar.org/schemas/sdp/Pagination.json",
  "title": "Pagination",
  "type": "object",
  "properties": {
    "next": {
      "type": "string",
      "example": "?page=3&page_limit=2"
    },
    "prev": {
      "type": "string",
      "example": "?page=1&page_limit=2"
    },
    "pages": {
      "type": "integer",
      "example": 8
    },
    "total": {
      "type": "integer",
      "example": 16
    }
  }
}