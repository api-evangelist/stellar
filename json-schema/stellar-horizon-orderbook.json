{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://developers.stellar.org/schemas/horizon/OrderBook.json",
  "title": "OrderBook",
  "type": "object",
  "properties": {
    "bids": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price_r": {
            "type": "object",
            "properties": {
              "n": {
                "type": "integer"
              },
              "d": {
                "type": "integer"
              }
            }
          },
          "price": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          }
        }
      }
    },
    "asks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "price_r": {
            "type": "object",
            "properties": {
              "n": {
                "type": "integer"
              },
              "d": {
                "type": "integer"
              }
            }
          },
          "price": {
            "type": "string"
          },
          "amount": {
            "type": "string"
          }
        }
      }
    },
    "base": {
      "type": "object",
      "properties": {
        "asset_type": {
          "type": "string"
        }
      }
    },
    "counter": {
      "type": "object",
      "properties": {
        "asset_type": {
          "type": "string"
        },
        "asset_code": {
          "type": "string"
        },
        "asset_issuer": {
          "$ref": "#/components/schemas/address"
        }
      }
    }
  }
}